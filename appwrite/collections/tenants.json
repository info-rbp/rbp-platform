{
  "id": "tenants",
  "name": "Tenants",
  "documentSecurity": true,
  "permissions": {
    "read": ["team:admins"],
    "create": ["team:admins"],
    "update": ["team:admins"],
    "delete": ["team:admins"]
  },
  "attributes": [
    { "key": "tenant_name", "type": "string", "size": 255, "required": true },
    { "key": "status", "type": "string", "size": 32, "required": true },
    { "key": "plan_code", "type": "string", "size": 64, "required": false }
  ]
}

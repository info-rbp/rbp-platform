{
  "id": "entitlements",
  "name": "Entitlements",
  "documentSecurity": true,
  "permissions": { "read": ["team:admins", "role:users"], "create": ["team:admins"], "update": ["team:admins"], "delete": ["team:admins"] },
  "attributes": [
    { "key": "entitlement_key", "type": "string", "size": 64, "required": true },
    { "key": "label", "type": "string", "size": 255, "required": true },
    { "key": "enabled_by_default", "type": "boolean", "required": true }
  ]
}

{
  "id": "rbp_documents",
  "name": "RBP Documents",
  "fileSecurity": true,
  "enabled": true,
  "maximumFileSize": 20000000,
  "allowedFileExtensions": [
    "pdf",
    "doc",
    "docx",
    "png",
    "jpg",
    "jpeg"
  ],
  "permissions": {
    "read": [
      "team:admins",
      "role:users"
    ],
    "create": [
      "team:admins"
    ],
    "update": [
      "team:admins"
    ],
    "delete": [
      "team:admins"
    ]
  }
}

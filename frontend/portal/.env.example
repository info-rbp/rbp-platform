# Frontend-only fallbacks for local Vite runs.
#
# Production frontend state should come from the backend
# rbp_app.api.runtime.get_public_runtime_config endpoint.

VITE_RBP_ENVIRONMENT=qa
VITE_RBP_ENABLE_STRIPE=true
VITE_RBP_STRIPE_MODE=test
VITE_RBP_ENABLE_EMAIL_NOTIFICATIONS=true
VITE_RBP_EMAIL_SANDBOX_MODE=true
VITE_RBP_ENABLE_APPLICATION_PROVISIONING=false
VITE_RBP_ENABLE_APPLICATION_INTEREST=true
VITE_RBP_ENABLE_ADMIN_APPLICATIONS=true

# RBP Frontend Local Environment Example
# Frontend variables are public at build time. Do not put secrets here.

VITE_QA_ENVIRONMENT=false
VITE_PUBLIC_SITE_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000

VITE_ENABLE_APPLICATIONS=false
VITE_ENABLE_APPLICATION_INTEREST=true
VITE_ENABLE_APPLICATION_PROVISIONING=false
VITE_ENABLE_ADMIN_APPLICATIONS=true
VITE_ENABLE_STRIPE_CHECKOUT=false
VITE_ENABLE_EMAIL_NOTIFICATIONS=false
VITE_EMAIL_SANDBOX_MODE=true
VITE_ENABLE_MOCK_AUTH=true
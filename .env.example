# RBP Platform root environment example

# Environment
RBP_ENV=development

# Frontend
FRONTEND_PORT=5173
FRONTEND_API_BASE_URL=http://localhost:8000

# Frappe
FRAPPE_SITE_NAME=rbp.localhost
FRAPPE_PORT=8000

# Database / cache placeholders
DB_HOST=localhost
REDIS_CACHE=redis://localhost:6379/0
REDIS_QUEUE=redis://localhost:6379/1

# Secrets must not be committed.
# Use local .env files or deployment secret managers.

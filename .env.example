# RBP Platform Backend Environment Example
# Do not place real secrets in this file.

RBP_ENVIRONMENT=local

RBP_ENABLE_STRIPE=false
RBP_STRIPE_MODE=test
RBP_ENABLE_EMAIL_NOTIFICATIONS=false
RBP_EMAIL_SANDBOX_MODE=true
RBP_ENABLE_APPLICATION_PROVISIONING=false
RBP_ENABLE_APPLICATION_INTEREST=true
RBP_ENABLE_ADMIN_APPLICATIONS=true

RBP_STRIPE_SECRET_KEY=
RBP_STRIPE_WEBHOOK_SECRET=
RBP_STRIPE_SUCCESS_URL=http://localhost:5173/membership/confirmation?session_id={CHECKOUT_SESSION_ID}
RBP_STRIPE_CANCEL_URL=http://localhost:5173/portal/membership/checkout?cancelled=true

RBP_EMAIL_FROM=
RBP_EMAIL_REPLY_TO=
RBP_QA_EMAIL_RECIPIENTS=
RBP_ADMIN_NOTIFICATION_RECIPIENTS=

RBP_PUBLIC_SITE_URL=http://localhost:5173
RBP_API_BASE_URL=http://localhost:8000

RBP_QA_ENVIRONMENT=false
{
  "name": "rbp-appwrite-mcp-server",
  "version": "0.1.0",
  "description": "MCP server exposing universal Appwrite read/write tools for RBP backend implementation and QA.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "node-appwrite": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}

# RBP Platform Production Backend Environment Example
# Do not place real secrets in this file.

RBP_ENVIRONMENT=production

RBP_ENABLE_STRIPE=true
RBP_STRIPE_MODE=live
RBP_ENABLE_EMAIL_NOTIFICATIONS=true
RBP_EMAIL_SANDBOX_MODE=false
RBP_ENABLE_APPLICATION_PROVISIONING=false
RBP_ENABLE_APPLICATION_INTEREST=true
RBP_ENABLE_ADMIN_APPLICATIONS=true

RBP_STRIPE_SECRET_KEY=
RBP_STRIPE_WEBHOOK_SECRET=
RBP_STRIPE_SUCCESS_URL=https://www.remotebusinesspartner.com.au/membership/confirmation?session_id={CHECKOUT_SESSION_ID}
RBP_STRIPE_CANCEL_URL=https://www.remotebusinesspartner.com.au/portal/membership/checkout?cancelled=true

RBP_EMAIL_FROM=notifications@remotebusinesspartner.com.au
RBP_EMAIL_REPLY_TO=support@remotebusinesspartner.com.au
RBP_QA_EMAIL_RECIPIENTS=
RBP_ADMIN_NOTIFICATION_RECIPIENTS=

RBP_PUBLIC_SITE_URL=https://www.remotebusinesspartner.com.au
RBP_API_BASE_URL=https://api.remotebusinesspartner.com.au

RBP_QA_ENVIRONMENT=false